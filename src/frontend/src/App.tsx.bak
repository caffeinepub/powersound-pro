          </div>
          <div
            style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 14 }}
          >
            {ENGINE_CONFIG.map((eng, idx) => (
              <div
                key={eng.name}
                data-ocid={`engine.panel.${idx + 1}`}
                style={{
                  ...PANEL,
                  border: `1px solid ${engineStates[idx] && commanderOn ? "#00ff88" : engineStates[idx] ? "#2a5040" : "#1e2e4a"}`,
                }}
              >
