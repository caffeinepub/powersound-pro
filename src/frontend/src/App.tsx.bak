  letterSpacing: 1,
};

// ─── VERTICAL SLIDER ─────────────────────────────────────────────────────────
// CRITICAL: uses ONLY transform:rotate(-90deg) — NO writing-mode anywhere.

function VerticalSlider({
  value,
  min = -12,
  max = 12,
  step = 0.1,
  onChange,
  sliderClass = "eq-slider",
  height = 120,
  width = 32,
}: {
  value: number;
  min?: number;
  max?: number;
  step?: number;
  onChange: (v: number) => void;
  sliderClass?: string;
  height?: number;
  width?: number;
}) {
  // innerOffset centres the rotated (height×width) div inside the (width×height) wrapper
  const innerOffset = (height - width) / 2;
  return (
    <div
      style={{
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        height: `${height}px`,
        width: `${width}px`,
        position: "relative",
        flexShrink: 0,
      }}
    >
      <div
        style={{
          width: `${height}px`,
          height: `${width}px`,
          transform: "rotate(-90deg)",
          position: "absolute",
          top: `${innerOffset}px`,
          left: `${-innerOffset}px`,
        }}
      >
        <input
          type="range"
          min={min}
          max={max}
          step={step}
          value={value}
          onChange={(e) => onChange(Number.parseFloat(e.target.value))}
          className={sliderClass}
          style={{ width: "100%", height: "100%", display: "block" }}
        />
      </div>
    </div>
  );
}

// ─── AUDIO REFS TYPE ──────────────────────────────────────────────────────────

interface AudioRefs {
  ctx: AudioContext | null;
  source: AudioBufferSourceNode | null;
  engineFilters: BiquadFilterNode[];
  engineGains: GainNode[];
  mixGain: GainNode | null;
  bass80: BiquadFilterNode | null;
  eq10: BiquadFilterNode[];
  eq31: BiquadFilterNode[];
  compressor: DynamicsCompressorNode | null;
  shaper1: WaveShaperNode | null;
  shaper2: WaveShaperNode | null;
  masterGain: GainNode | null;
  analyser: AnalyserNode | null;
}

// ─── MAIN APP ─────────────────────────────────────────────────────────────────

export default function App() {
  // ── Book animation
  const [bookOpen, setBookOpen] = useState(false);

  // ── UI state
  const [commanderOn, setCommanderOn] = useState(false);
  const [engineStates, setEngineStates] = useState<boolean[]>([
    true,
    true,
    true,
    true,
  ]);
  const [eq10, setEq10] = useState<number[]>(Array(10).fill(0));
  const [eq31, setEq31] = useState<number[]>(Array(31).fill(0));
  const [battery, setBattery] = useState(0);
  const [isCharging, setIsCharging] = useState(false);
  const [isPlaying, setIsPlaying] = useState(false);
  const [loudBooster, setLoudBooster] = useState(0);
  const [masterVolume, setMasterVolume] = useState(850);
  const [bass80On, setBass80On] = useState(false);
  const [autoGenOn, setAutoGenOn] = useState(false);
  const [signalLevels, setSignalLevels] = useState<number[]>([0, 0, 0, 0]);
  const [freqBars, setFreqBars] = useState<number[]>(Array(20).fill(0));
  const [fileName, setFileName] = useState<string | null>(null);
  const [audioBuffer, setAudioBuffer] = useState<AudioBuffer | null>(null);
  const [playOffset, setPlayOffset] = useState(0);
  const [playStartTime, setPlayStartTime] = useState(0);

  // ── Audio refs
  const ar = useRef<AudioRefs>({
    ctx: null,
    source: null,
    engineFilters: [],
    engineGains: [],
    mixGain: null,
    bass80: null,
    eq10: [],
    eq31: [],
    compressor: null,
    shaper1: null,
    shaper2: null,
    masterGain: null,
    analyser: null,
  });
  const chargingTimerRef = useRef<ReturnType<typeof setInterval> | null>(null);
  const drainTimerRef = useRef<ReturnType<typeof setInterval> | null>(null);
  const animFrameRef = useRef<number | null>(null);
  const autoGenTimerRef = useRef<ReturnType<typeof setInterval> | null>(null);

  // ── Restore from localStorage
  useEffect(() => {
    try {
      const raw = localStorage.getItem("psp-state");
      if (raw) {
        const s = JSON.parse(raw);
        if (typeof s.battery === "number") setBattery(s.battery);
        if (Array.isArray(s.engineStates)) setEngineStates(s.engineStates);
        if (Array.isArray(s.eq10)) setEq10(s.eq10);
        if (Array.isArray(s.eq31)) setEq31(s.eq31);
        if (typeof s.commanderOn === "boolean") setCommanderOn(s.commanderOn);
        if (typeof s.loudBooster === "number") setLoudBooster(s.loudBooster);
        if (typeof s.masterVolume === "number") setMasterVolume(s.masterVolume);
        if (typeof s.bass80On === "boolean") setBass80On(s.bass80On);
      }
    } catch (_) {}
    const t = setTimeout(() => setBookOpen(true), 6300);
    return () => clearTimeout(t);
  }, []);

  // ── Persist to localStorage
  useEffect(() => {
    try {
      localStorage.setItem(
        "psp-state",
        JSON.stringify({
          battery,
          engineStates,
          eq10,
          eq31,
          commanderOn,
          loudBooster,
          masterVolume,
          bass80On,
        }),
      );
    } catch (_) {}
  }, [
    battery,
    engineStates,
    eq10,
    eq31,
    commanderOn,
    loudBooster,
    masterVolume,
    bass80On,
  ]);

  // ── Battery charge timer
  useEffect(() => {
    if (chargingTimerRef.current) clearInterval(chargingTimerRef.current);
    if (!isCharging) return;
    chargingTimerRef.current = setInterval(() => {
      setBattery((prev) => {
        if (prev >= 100) {
          setIsCharging(false);
          return 100;
        }
        return prev + 1;
      });
    }, 400);
    return () => {
      if (chargingTimerRef.current) clearInterval(chargingTimerRef.current);
    };
  }, [isCharging]);

  // ── Analyser loop
  const startAnalyser = useCallback(() => {
    if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    const loop = () => {
      const analyser = ar.current.analyser;
      if (!analyser) return;
      const data = new Uint8Array(analyser.frequencyBinCount);
      analyser.getByteFrequencyData(data);
      const bars = Array(20)
        .fill(0)
        .map((_, i) => {
          const s = Math.floor((i / 20) * data.length);
          const e = Math.floor(((i + 1) / 20) * data.length);
          let sum = 0;
          for (let j = s; j < e; j++) sum += data[j];
          return sum / Math.max(1, e - s) / 255;
        });
      setFreqBars(bars);
      setSignalLevels([
        (data[1] ?? 0) / 255,
        (data[6] ?? 0) / 255,
        (data[18] ?? 0) / 255,
        (data[35] ?? 0) / 255,
      ]);
      animFrameRef.current = requestAnimationFrame(loop);
    };
    animFrameRef.current = requestAnimationFrame(loop);
  }, []);

  // ── Auto frequency generator
  useEffect(() => {
    if (autoGenTimerRef.current) clearInterval(autoGenTimerRef.current);
    if (!autoGenOn || !isPlaying) return;
    autoGenTimerRef.current = setInterval(() => {
      const analyser = ar.current.analyser;
      if (!analyser) return;
      const data = new Uint8Array(analyser.frequencyBinCount);
      analyser.getByteFrequencyData(data);
      setEq10((prev) =>
        prev.map((val, i) => {
          const binIdx = Math.min(
            Math.floor((EQ10_FREQS[i] / 20000) * data.length),
            data.length - 1,
          );
          const level = (data[binIdx] ?? 0) / 255;
          const nudge = (level - 0.5) * 0.4;
          const next = Math.max(-12, Math.min(12, val + nudge));
          const f = ar.current.eq10[i];
          if (f) f.gain.value = next;
          return next;
        }),
      );
    }, 500);
    return () => {
      if (autoGenTimerRef.current) clearInterval(autoGenTimerRef.current);
    };
  }, [autoGenOn, isPlaying]);

  // ── Build audio chain (called on every Play)
  const buildChain = useCallback(
    (
      ctx: AudioContext,
      buf: AudioBuffer,
      engStates: boolean[],
      eq10vals: number[],
      eq31vals: number[],
      vol: number,
    ) => {
      const r = ar.current;

      // Source
      const source = ctx.createBufferSource();
      source.buffer = buf;

      // 4 parallel engine filters → engineGains → mixGain
      r.engineFilters = [];
      r.engineGains = [];
      const mixGain = ctx.createGain();
      mixGain.gain.value = 0.25; // merge 4 parallel outputs
      r.mixGain = mixGain;

      for (let i = 0; i < 4; i++) {
        const cfg = ENGINE_CONFIG[i];
        const filter = ctx.createBiquadFilter();
        filter.type = cfg.type;
        filter.frequency.value = cfg.freq;
        if (cfg.q) filter.Q.value = cfg.q;
        const gn = ctx.createGain();
        gn.gain.value = engStates[i] ? 1 : 0;
        source.connect(filter);
        filter.connect(gn);
        gn.connect(mixGain);
        r.engineFilters.push(filter);
        r.engineGains.push(gn);
      }

      // 80 Hz low-shelf
      const bass80 = ctx.createBiquadFilter();
      bass80.type = "lowshelf";
      bass80.frequency.value = 80;
      bass80.gain.value = 0;
      r.bass80 = bass80;
      mixGain.connect(bass80);

      // 10-band EQ (series)
      r.eq10 = [];
      let prev: AudioNode = bass80;
      for (let i = 0; i < 10; i++) {
        const f = ctx.createBiquadFilter();
        f.type = "peaking";
        f.frequency.value = EQ10_FREQS[i];
        f.Q.value = 1.4;
        f.gain.value = eq10vals[i];
        prev.connect(f);
        prev = f;
        r.eq10.push(f);
      }

      // 31-band EQ (series)
      r.eq31 = [];
      for (let i = 0; i < 31; i++) {
        const f = ctx.createBiquadFilter();
        f.type = "peaking";
        f.frequency.value = EQ31_FREQS[i];
        f.Q.value = 2.8;
        f.gain.value = eq31vals[i];
        prev.connect(f);
        prev = f;
        r.eq31.push(f);
      }

      // Compressor (Loud Booster — signal shaper, no gain multiplication)
      const comp = ctx.createDynamicsCompressor();
      comp.threshold.value = -24;
      comp.knee.value = 30;
      comp.ratio.value = 4;
      comp.attack.value = 0.003;
      comp.release.value = 0.25;
      r.compressor = comp;
      prev.connect(comp);

      // Stabilizer (two gentle wave shapers)
      const makeShaper = (amt: number) => {
        const n = 256;
        const curve = new Float32Array(n);
        for (let i = 0; i < n; i++) {
          const x = (i * 2) / n - 1;
          curve[i] = ((Math.PI + amt) * x) / (Math.PI + amt * Math.abs(x));
        }
        return curve;
      };
      const s1 = ctx.createWaveShaper();
      s1.curve = makeShaper(2);
      s1.oversample = "4x";
      r.shaper1 = s1;
      comp.connect(s1);
      const s2 = ctx.createWaveShaper();
      s2.curve = makeShaper(1);
      s2.oversample = "4x";
      r.shaper2 = s2;
      s1.connect(s2);

      // Master gain (0–1, slider labeled 0–1700)
      const mg = ctx.createGain();
      mg.gain.value = vol / 1700;
      r.masterGain = mg;
      s2.connect(mg);

      // Analyser
      const analyser = ctx.createAnalyser();
      analyser.fftSize = 512;
      r.analyser = analyser;
      mg.connect(analyser);
      mg.connect(ctx.destination);

      return source;
    },
    [],
  );

  // ── File load
  const handleFileLoad = useCallback(
    async (e: React.ChangeEvent<HTMLInputElement>) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const r = ar.current;
      // Tear down existing
      if (r.source) {
        try {
          r.source.stop();
        } catch (_) {}
        r.source = null;
      }
      if (r.ctx) {
        try {
          await r.ctx.close();
        } catch (_) {}
        r.ctx = null;
      }
      if (animFrameRef.current) {
        cancelAnimationFrame(animFrameRef.current);
        animFrameRef.current = null;
      }
      if (drainTimerRef.current) {
        clearInterval(drainTimerRef.current);
        drainTimerRef.current = null;
      }
      setIsPlaying(false);
      setPlayOffset(0);
      setFileName(file.name);
      setFreqBars(Array(20).fill(0));
      setSignalLevels([0, 0, 0, 0]);

      const arrayBuf = await file.arrayBuffer();
      const ctx = new AudioContext();
      const buf = await ctx.decodeAudioData(arrayBuf);
      ar.current.ctx = ctx;
      setAudioBuffer(buf);
      e.target.value = "";
    },
    [],
  );

  // ── Play
  const handlePlay = useCallback(() => {
    const r = ar.current;
    if (!audioBuffer || !r.ctx) return;
    if (battery <= 0) return;
    if (r.source) {
      try {
        r.source.stop();
      } catch (_) {}
      r.source = null;
    }
    if (animFrameRef.current) {
      cancelAnimationFrame(animFrameRef.current);
      animFrameRef.current = null;
    }
    if (drainTimerRef.current) {
      clearInterval(drainTimerRef.current);
      drainTimerRef.current = null;
    }

    const source = buildChain(
      r.ctx,
      audioBuffer,
      engineStates,
      eq10,
      eq31,
      masterVolume,
    );
    source.start(0, playOffset);
    r.source = source;
    setPlayStartTime(r.ctx.currentTime - playOffset);
    setIsPlaying(true);
    startAnalyser();

    source.onended = () => {
      setIsPlaying(false);
      setPlayOffset(0);
      setFreqBars(Array(20).fill(0));
      setSignalLevels([0, 0, 0, 0]);
      if (drainTimerRef.current) clearInterval(drainTimerRef.current);
    };

    // Battery drain
    drainTimerRef.current = setInterval(() => {
      setBattery((prev) => {
        if (prev <= 0) {
          if (r.source) {
            try {
              r.source.stop();
            } catch (_) {}
            r.source = null;
          }
          return 0;
        }
        return prev - 0.3;
      });
    }, 1000);
  }, [
    audioBuffer,
    battery,
    buildChain,
    engineStates,
    eq10,
    eq31,
    masterVolume,
    playOffset,
    startAnalyser,
  ]);

  // ── Pause
  const handlePause = useCallback(() => {
    const r = ar.current;
    if (!r.ctx || !r.source) return;
    const elapsed = r.ctx.currentTime - playStartTime;
    setPlayOffset(Math.min(elapsed, audioBuffer?.duration ?? elapsed));
    try {
      r.source.stop();
    } catch (_) {}
    r.source = null;
    setIsPlaying(false);
    if (animFrameRef.current) {
      cancelAnimationFrame(animFrameRef.current);
      animFrameRef.current = null;
    }
    if (drainTimerRef.current) {
      clearInterval(drainTimerRef.current);
      drainTimerRef.current = null;
    }
    setFreqBars(Array(20).fill(0));
    setSignalLevels([0, 0, 0, 0]);
  }, [audioBuffer, playStartTime]);

  // ── Stop
  const handleStop = useCallback(() => {
    const r = ar.current;
    if (r.source) {
      try {
        r.source.stop();
      } catch (_) {}
      r.source = null;
    }
    setIsPlaying(false);
    setPlayOffset(0);
    if (animFrameRef.current) {
      cancelAnimationFrame(animFrameRef.current);
      animFrameRef.current = null;
    }
    if (drainTimerRef.current) {
      clearInterval(drainTimerRef.current);
      drainTimerRef.current = null;
    }
    setFreqBars(Array(20).fill(0));
    setSignalLevels([0, 0, 0, 0]);
  }, []);

  // ── Engine toggle
  const toggleEngine = useCallback((idx: number) => {
    setEngineStates((prev) => {
      const next = [...prev];
      next[idx] = !next[idx];
      const g = ar.current.engineGains[idx];
      if (g) g.gain.value = next[idx] ? 1 : 0;
      return next;
    });
  }, []);

  // ── EQ updates
  const updateEq10 = useCallback((idx: number, val: number) => {
    setEq10((prev) => {
      const next = [...prev];
      next[idx] = val;
      const f = ar.current.eq10[idx];
      if (f) f.gain.value = val;
      return next;
    });
  }, []);

  const updateEq31 = useCallback((idx: number, val: number) => {
    setEq31((prev) => {
      const next = [...prev];
      next[idx] = val;
      const f = ar.current.eq31[idx];
      if (f) f.gain.value = val;
      return next;
    });
  }, []);

  const flattenEq10 = useCallback(() => {
    const flat = Array(10).fill(0);
    setEq10(flat);
    flat.forEach((v, i) => {
      const f = ar.current.eq10[i];
      if (f) f.gain.value = v;
    });
  }, []);

  const applyInstrument = useCallback((name: string) => {
    const preset = INSTRUMENT_PRESETS[name];
    if (!preset) return;
    setEq10([...preset]);
    preset.forEach((v, i) => {
      const f = ar.current.eq10[i];
      if (f) f.gain.value = v;
    });
  }, []);

  const applyEq31Preset = useCallback((name: string) => {
    const preset = EQ31_PRESETS[name];
    if (!preset) return;
    setEq31([...preset]);
    preset.forEach((v, i) => {
      const f = ar.current.eq31[i];
      if (f) f.gain.value = v;
    });
  }, []);

  // ── Master volume
  const updateMasterVolume = useCallback((val: number) => {
    setMasterVolume(val);
    const mg = ar.current.masterGain;
    if (mg) mg.gain.value = val / 1700;
  }, []);

  // ── Loud booster
  const updateLoudBooster = useCallback((val: number) => {
    setLoudBooster(val);
    const comp = ar.current.compressor;
    if (comp) {
      const n = val / 1700;
      comp.threshold.value = -24 + n * 12;
      comp.ratio.value = 4 + n * 8;
    }
  }, []);

  // ── 80Hz bass
  const toggleBass80 = useCallback(() => {
    setBass80On((prev) => {
      const next = !prev;
      const f = ar.current.bass80;
      if (f) f.gain.value = next ? 5 : 0;
      return next;
    });
  }, []);

  // ── Cleanup
  useEffect(() => {
    return () => {
      const r = ar.current;
      if (r.source) {
        try {
          r.source.stop();
        } catch (_) {}
      }
      if (r.ctx) {
        try {
          r.ctx.close();
        } catch (_) {}
      }
      if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
      if (drainTimerRef.current) clearInterval(drainTimerRef.current);
      if (chargingTimerRef.current) clearInterval(chargingTimerRef.current);
      if (autoGenTimerRef.current) clearInterval(autoGenTimerRef.current);
    };
  }, []);

  // ── Derived
  const batteryColor =
    battery > 50 ? "#00ff88" : battery > 20 ? "#f5c542" : "#ff5533";
  const green = (on: boolean) => (on ? "#00ff88" : "#1e2e4a");
  const greenText = (on: boolean) => (on ? "#00ff88" : "#5a7090");

  // ─── RENDER ──────────────────────────────────────────────────────────────────
  return (
    <div
      style={{
        background: "#080d18",
        minHeight: "100vh",
        fontFamily: "'Satoshi', sans-serif",
        color: "#e8edf5",
        overflowX: "hidden",
      }}
    >
      {/* ── Book Opening Animation ── */}
      <AnimatePresence>
        {!bookOpen && (
          <>
            {/* Left cover */}
            <motion.div
              key="book-left"
              initial={{ rotateY: 0 }}
              animate={{ rotateY: -95 }}
              exit={{ opacity: 0 }}
              transition={{ duration: 6, ease: [0.4, 0.0, 0.2, 1] }}
              style={{
                position: "fixed",
                top: 0,
                left: 0,
                width: "50vw",
                height: "100vh",
                background:
                  "linear-gradient(160deg, #0e1830 0%, #1a2d50 50%, #0a0e1a 100%)",
                zIndex: 9999,
                transformOrigin: "left center",
                transformStyle: "preserve-3d",
                borderRight: "3px solid #f5c542",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                perspective: 1200,
              }}
            >
              <div style={{ textAlign: "center" }}>
                <div
                  style={{
                    fontSize: 56,
                    fontWeight: 900,
                    color: "#f5c542",
                    letterSpacing: 4,
                    textShadow: "0 0 30px rgba(245,197,66,0.7)",
                  }}
                >
                  POWER
                </div>
                <div
                  style={{
                    fontSize: 16,
                    color: "#8aa0c0",
                    letterSpacing: 10,
                    marginTop: 4,
                  }}
                >
                  SOUND
                </div>
              </div>
            </motion.div>
            {/* Right cover */}
            <motion.div
              key="book-right"
              initial={{ rotateY: 0 }}
              animate={{ rotateY: 95 }}
              exit={{ opacity: 0 }}
              transition={{ duration: 6, ease: [0.4, 0.0, 0.2, 1] }}
              style={{
                position: "fixed",
                top: 0,
                right: 0,
                width: "50vw",
                height: "100vh",
                background:
                  "linear-gradient(200deg, #0a0e1a 0%, #1a2d50 50%, #0e1830 100%)",
                zIndex: 9999,
                transformOrigin: "right center",
                transformStyle: "preserve-3d",
                borderLeft: "3px solid #f5c542",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                perspective: 1200,
              }}
            >
              <div style={{ textAlign: "center" }}>
                <div
                  style={{
                    fontSize: 56,
                    fontWeight: 900,
                    color: "#f5c542",
                    letterSpacing: 4,
                    textShadow: "0 0 30px rgba(245,197,66,0.7)",
                  }}
                >
                  PRO
                </div>
                <div
                  style={{
                    fontSize: 16,
                    color: "#8aa0c0",
                    letterSpacing: 10,
                    marginTop: 4,
                  }}
                >
                  AUDIO
                </div>
              </div>
            </motion.div>
          </>
        )}
      </AnimatePresence>

      {/* ── Main Content ── */}
      <div
        style={{ maxWidth: 1380, margin: "0 auto", padding: "20px 16px 40px" }}
      >
        {/* ── Header ── */}
        <header
          style={{
            textAlign: "center",
            padding: "28px 0 32px",
            borderBottom: "2px solid #1e3060",
            marginBottom: 28,
          }}
        >
          <div
            style={{
              fontFamily: "'Bricolage Grotesque', sans-serif",
              fontSize: 52,
              fontWeight: 900,
              letterSpacing: 5,
              color: "#f5c542",
              textShadow:
                "0 0 24px rgba(245,197,66,0.5), 0 2px 8px rgba(0,0,0,0.8)",
            }}
          >
            PowerSound Pro
          </div>
          <div
            style={{
              display: "flex",
              gap: 10,
              justifyContent: "center",
              marginTop: 14,
              flexWrap: "wrap",
            }}
          >
            {["A⁺", "B⁺", "C⁺", "D⁺"].map((b) => (
              <span
                key={b}
                style={{
                  background: "linear-gradient(135deg, #f5c542, #d4a012)",
                  color: "#0a0e1a",
                  fontWeight: 900,
                  fontSize: 15,
                  padding: "5px 14px",
                  borderRadius: 5,
                  boxShadow: "0 0 14px rgba(245,197,66,0.55)",
                }}
              >
                {b}
              </span>
            ))}
          </div>
          <div
            style={{
              color: "#4a6080",
              fontSize: 11,
              letterSpacing: 3,
              marginTop: 10,
            }}
          >
            HIGH-CLASS AUDIO PROCESSING SYSTEM — SRS 22 CHIP
          </div>
        </header>

        {/* ── File Picker ── */}
        <section style={{ marginBottom: 20 }}>
          <div style={PANEL}>
            <div style={PANEL_TITLE}>▶ LOAD MUSIC FILE</div>
            <div
              style={{
                display: "flex",
                alignItems: "center",
                gap: 16,
                flexWrap: "wrap",
              }}
            >
              <label
                data-ocid="file.upload_button"
                style={{ ...BTN_GOLD, display: "inline-block" }}
              >
                📂 BROWSE FILE
                <input
                  type="file"
                  accept="audio/*"
                  onChange={handleFileLoad}
                  style={{ display: "none" }}
                />
              </label>
              <div
                style={{
                  color: fileName ? "#00ff88" : "#4a6080",
                  fontSize: 13,
                }}
              >
                {fileName ?? "No file loaded — select an audio file to begin"}
              </div>
            </div>
          </div>
        </section>

        {/* ── Battery ── */}
        <section style={{ marginBottom: 20 }}>
          <div style={PANEL}>
            <div style={PANEL_TITLE}>⚡ BATTERY SYSTEM</div>
            <div
              style={{
                display: "flex",
                alignItems: "center",
                gap: 20,
                flexWrap: "wrap",
              }}
            >
              {/* Battery bar */}
              <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                <div
                  style={{
                    width: 180,
                    height: 34,
                    border: `2px solid ${batteryColor}`,
                    borderRadius: 5,
                    position: "relative",
                    background: "#06090f",
                    overflow: "hidden",
                  }}
                >
                  <div
                    style={{
                      width: `${battery}%`,
                      height: "100%",
                      background: `linear-gradient(90deg, ${batteryColor}88, ${batteryColor})`,
                      transition: "width 0.4s",
                      borderRadius: 3,
                    }}
                  />
                  <div
                    style={{
                      position: "absolute",
                      inset: 0,
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "center",
                      fontWeight: 800,
                      fontSize: 14,
                      color: "#fff",
                      textShadow: "0 1px 3px #000",
                    }}
                  >
                    {battery.toFixed(0)}%
                  </div>
                </div>
                <div
                  style={{
                    width: 8,
                    height: 16,
                    background: batteryColor,
                    borderRadius: "0 3px 3px 0",
                  }}
                />
              </div>
              <button
                type="button"
                data-ocid="battery.primary_button"
                onClick={() => setIsCharging(true)}
                style={isCharging ? BTN_GREEN : BTN_GOLD}
              >
                {isCharging ? "⚡ CHARGING..." : "CHARGE"}
              </button>
              <div
                style={{
                  color: battery <= 0 ? "#ff5533" : "#4a6080",
                  fontSize: 12,
                }}
              >
                {battery <= 0
                  ? "⚠ BATTERY DEAD — charge to play"
                  : battery >= 100
                    ? "✓ FULLY CHARGED"
                    : isCharging
                      ? "Charging amp power..."
                      : `Powering amplifier — ${battery.toFixed(0)}%`}
              </div>
            </div>
          </div>
        </section>

        {/* ── Transport ── */}
        <section style={{ marginBottom: 20 }}>
          <div style={PANEL}>
            <div style={PANEL_TITLE}>▶ TRANSPORT CONTROLS</div>
            <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
              <button
                type="button"
                data-ocid="transport.primary_button"
                onClick={handlePlay}
                disabled={!audioBuffer || battery <= 0}
                style={{
                  ...BTN_GOLD,
                  opacity: !audioBuffer || battery <= 0 ? 0.45 : 1,
                  fontSize: 14,
                  padding: "10px 28px",
                }}
              >
                ▶ PLAY
              </button>
              <button
                type="button"
                data-ocid="transport.secondary_button"
                onClick={handlePause}
                disabled={!isPlaying}
                style={{
                  ...BTN_GOLD,
                  opacity: !isPlaying ? 0.45 : 1,
                  fontSize: 14,
                  padding: "10px 28px",
                }}
              >
                ⏸ PAUSE
              </button>
              <button
                type="button"
                data-ocid="transport.delete_button"
                onClick={handleStop}
                style={{ ...BTN_MUTED, fontSize: 14, padding: "10px 28px" }}
              >
                ⏹ STOP
              </button>
              {isPlaying && (
                <div
                  data-ocid="transport.success_state"
                  style={{
                    display: "flex",
                    alignItems: "center",
                    gap: 6,
                    color: "#00ff88",
                    fontSize: 12,
                    fontWeight: 700,
                  }}
                >
                  <motion.div
                    animate={{ opacity: [1, 0.3, 1] }}
                    transition={{
                      repeat: Number.POSITIVE_INFINITY,
                      duration: 1,
                    }}
                    style={{
                      width: 8,
                      height: 8,
                      borderRadius: "50%",
                      background: "#00ff88",
                    }}
                  />
                  PLAYING
                </div>
              )}
            </div>
          </div>
        </section>

        {/* ── Commander ── */}
        <section style={{ marginBottom: 20 }}>
          <div
            style={{
              background: "linear-gradient(135deg, #0c1828 0%, #142040 100%)",
              border: `2px solid ${commanderOn ? "#f5c542" : "#1e3060"}`,
              borderRadius: 12,
              padding: 24,
              boxShadow: commanderOn
                ? "0 0 36px rgba(245,197,66,0.3), inset 0 0 24px rgba(245,197,66,0.04)"
                : "0 4px 16px rgba(0,0,0,0.5)",
            }}
          >
            {/* Header row */}
            <div
              style={{
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between",
                marginBottom: 20,
                flexWrap: "wrap",
                gap: 12,
              }}
            >
              <div>
                <div
                  style={{
                    fontFamily: "'Bricolage Grotesque', sans-serif",
