  background: "#0d1528",
  border: "1px solid #1e2e4a",
  borderRadius: 10,
  padding: 20,
};

const PANEL_TITLE: React.CSSProperties = {
  color: "#f5c542",
  fontSize: 12,
  fontWeight: 800,
  letterSpacing: 2,
  marginBottom: 14,
  textTransform: "uppercase" as const,
};

const BTN_GOLD: React.CSSProperties = {
  background: "linear-gradient(135deg, #1a3a6c 0%, #0d2040 100%)",
  border: "1px solid #f5c542",
  color: "#f5c542",
  padding: "8px 18px",
  borderRadius: 6,
  cursor: "pointer",
  fontWeight: 700,
  fontSize: 11,
  letterSpacing: 1,
};

const BTN_GREEN: React.CSSProperties = {
  background: "#002a18",
  border: "1px solid #00ff88",
  color: "#00ff88",
  padding: "8px 18px",
  borderRadius: 6,
  cursor: "pointer",
  fontWeight: 700,
  fontSize: 11,
  letterSpacing: 1,
};

const BTN_MUTED: React.CSSProperties = {
