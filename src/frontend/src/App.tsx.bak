                  MASTER CONTROL SYSTEM — MEMORY GRID
                </div>
              </div>
              <button
                type="button"
                data-ocid="commander.toggle"
                onClick={() => setCommanderOn((v) => !v)}
                style={{
                  background: commanderOn
                    ? "linear-gradient(135deg, #003d20, #006040)"
                    : "linear-gradient(135deg, #1a2844, #0d1830)",
                  border: `2px solid ${commanderOn ? "#00ff88" : "#f5c542"}`,
                  color: commanderOn ? "#00ff88" : "#f5c542",
                  padding: "12px 36px",
                  borderRadius: 8,
                  cursor: "pointer",
                  fontWeight: 900,
                  fontSize: 16,
                  letterSpacing: 2,
                  boxShadow: commanderOn
                    ? "0 0 22px rgba(0,255,136,0.4)"
                    : "0 0 8px rgba(245,197,66,0.2)",
                }}
              >
                {commanderOn ? "● ON" : "○ OFF"}
              </button>
            </div>

            {/* SRS 22 Chip */}
            <div
              style={{
                background: "#06090f",
                border: "1px solid #1e2e4a",
                borderRadius: 8,
                padding: 16,
                marginBottom: 16,
              }}
            >
              <div
                style={{
                  fontSize: 10,
                  fontWeight: 700,
                  letterSpacing: 2,
                  color: "#f5c542",
                  marginBottom: 10,
                }}
              >
                SRS 22 CHIP — CLARITY ENGINE — ANTI-DISTORTION
              </div>
              <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
                {[
                  "NOISE GATE",
                  "A⁺ CLARITY",
                  "B⁺ WARMTH",
                  "C⁺ DETAIL",
                  "D⁺ OUTPUT",
                  "ANTI-CLIP",
                  "CHAIN LOCK",
                  "MONITOR",
                ].map((lbl) => (
                  <div
                    key={lbl}
                    style={{
                      background: commanderOn ? "#002a18" : "#0f1628",
                      border: `1px solid ${commanderOn ? "#00ff88" : "#1e2e4a"}`,
                      color: commanderOn ? "#00ff88" : "#4a6080",
                      fontSize: 10,
                      fontWeight: 700,
                      padding: "4px 9px",
                      borderRadius: 4,
                      letterSpacing: 1,
                    }}
                  >
                    {lbl}
                  </div>
                ))}
              </div>
            </div>

            {/* Memory Grid */}
            <div
              style={{
                background: "#06090f",
                border: "1px solid #1e2e4a",
                borderRadius: 8,
                padding: 16,
              }}
            >
              <div
                style={{
                  fontSize: 10,
                  fontWeight: 700,
                  letterSpacing: 2,
                  color: "#f5c542",
                  marginBottom: 10,
                }}
              >
                MEMORY GRID — ALL SYSTEMS
              </div>
              <div
                style={{
                  display: "grid",
                  gridTemplateColumns: "repeat(auto-fill, minmax(130px, 1fr))",
                  gap: 8,
                }}
              >
                {[
                  {
                    k: "ENGINES",
                    v: `${engineStates.filter(Boolean).length}/4 ACTIVE`,
                  },
                  { k: "10-BAND EQ", v: "10 BANDS LIVE" },
                  { k: "31-BAND EQ", v: "31 BANDS LIVE" },
                  { k: "BATTERY", v: `${battery.toFixed(0)}%` },
                  { k: "STABILIZER", v: "ONLINE" },
                  { k: "CHAIN BLOCK", v: "LOCKED" },
                  { k: "LOUD BOOST", v: `${loudBooster}` },
                  { k: "VOLUME", v: `${masterVolume}` },
                  { k: "80Hz BASS", v: bass80On ? "ON" : "OFF" },
                  { k: "AUTO GEN", v: autoGenOn ? "ACTIVE" : "STANDBY" },
                ].map((item) => (
                  <div
                    key={item.k}
                    style={{
                      background: "#0d1528",
                      border: `1px solid ${commanderOn ? "#00ff88" : "#1e2e4a"}`,
                      borderRadius: 5,
                      padding: "6px 10px",
                    }}
                  >
                    <div
                      style={{
                        color: "#4a6080",
                        fontSize: 9,
                        letterSpacing: 1,
                      }}
                    >
                      {item.k}
                    </div>
                    <div
                      style={{
                        color: commanderOn ? "#00ff88" : "#f5c542",
                        fontWeight: 800,
                        fontSize: 12,
                      }}
                    >
                      {item.v}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

        {/* ── Sound Engines 2×2 ── */}
        <section style={{ marginBottom: 20 }}>
          <div
