                        fontSize: 11,
                        padding: "2px 7px",
                        borderRadius: 3,
                      }}
                    >
                      {eng.cls}
                    </span>
                  </div>
                  <button
                    type="button"
                    data-ocid={`engine.toggle.${idx + 1}`}
                    onClick={() => toggleEngine(idx)}
                    style={engineStates[idx] ? BTN_GREEN : BTN_MUTED}
                  >
                    {engineStates[idx] ? "ON" : "OFF"}
                  </button>
                </div>
                <div
                  style={{
                    color: "#4a6080",
                    fontSize: 10,
                    letterSpacing: 1,
                    marginBottom: 8,
                  }}
                >
                  {eng.label}
                </div>
                {/* Signal bar */}
                <div
                  style={{
                    height: 7,
                    background: "#06090f",
                    borderRadius: 4,
                    border: "1px solid #1e2e4a",
                    overflow: "hidden",
                  }}
                >
                  <motion.div
                    animate={{
                      width: `${(engineStates[idx] ? signalLevels[idx] : 0) * 100}%`,
                    }}
                    transition={{ duration: 0.08 }}
                    style={{
                      height: "100%",
                      background: "#00ff88",
                      borderRadius: 4,
                      boxShadow: "0 0 6px #00ff88",
                    }}
                  />
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* ── 80Hz Bass Toggle ── */}
        <section style={{ marginBottom: 20 }}>
          <div
            style={{
              ...PANEL,
              display: "flex",
              alignItems: "center",
              gap: 20,
              flexWrap: "wrap",
            }}
          >
            <button
              type="button"
              data-ocid="bass80.toggle"
              onClick={toggleBass80}
              style={bass80On ? BTN_GREEN : BTN_GOLD}
            >
              {bass80On ? "● 80Hz BASS — ON" : "○ 80Hz BASS — OFF"}
            </button>
            <div style={{ color: "#4a6080", fontSize: 12 }}>
              Low-shelf filter at 80 Hz — wired to chain block
            </div>
          </div>
        </section>

        {/* ── 10-Band DJ EQ ── */}
        <section style={{ marginBottom: 20 }}>
          <div style={PANEL}>
            <div
              style={{
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between",
                marginBottom: 14,
                flexWrap: "wrap",
                gap: 10,
              }}
            >
              <div style={PANEL_TITLE}>🎚 10-BAND DJ EQUALIZER — A⁺B⁺C⁺D⁺</div>
              <button
                type="button"
                data-ocid="eq10.delete_button"
                onClick={flattenEq10}
                style={BTN_MUTED}
              >
                FLAT RESET
              </button>
            </div>

            {/* Instrument Presets */}
            <div
              style={{
                display: "flex",
                gap: 8,
                marginBottom: 20,
                flexWrap: "wrap",
              }}
            >
              {Object.keys(INSTRUMENT_PRESETS).map((name) => (
                <button
                  type="button"
                  key={name}
                  data-ocid="eq10.secondary_button"
                  onClick={() => applyInstrument(name)}
                  style={BTN_GOLD}
                >
                  {name}
                </button>
              ))}
            </div>

            {/* Sliders */}
            <div
              style={{
                display: "flex",
                gap: 8,
                alignItems: "flex-start",
                overflowX: "auto",
                paddingBottom: 8,
              }}
            >
              {EQ10_FREQS.map((freq, idx) => (
                <div
                  key={freq}
                  style={{
                    display: "flex",
                    flexDirection: "column",
                    alignItems: "center",
                    minWidth: 44,
                  }}
                >
                  {/* Value label */}
                  <div
                    style={{
                      fontSize: 10,
                      fontWeight: 700,
                      height: 16,
                      color:
                        eq10[idx] > 0
                          ? "#00ff88"
                          : eq10[idx] < 0
                            ? "#ff6644"
                            : "#4a6080",
                      marginBottom: 4,
                      textAlign: "center",
                    }}
                  >
                    {eq10[idx] !== 0
                      ? (eq10[idx] > 0 ? "+" : "") + eq10[idx].toFixed(1)
                      : "0"}
                  </div>
                  {/* Vertical slider */}
                  <VerticalSlider
                    value={eq10[idx]}
                    min={-12}
                    max={12}
                    step={0.1}
                    onChange={(v) => updateEq10(idx, v)}
                    sliderClass="eq-slider"
                    height={120}
                    width={32}
                  />
                  {/* Freq label */}
                  <div
                    style={{
                      fontSize: 9,
                      color: "#4a6080",
                      marginTop: 8,
                      textAlign: "center",
                    }}
                  >
                    {EQ10_LABELS[idx]}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── 31-Band Graphic EQ ── */}
        <section style={{ marginBottom: 20 }}>
          <div style={PANEL}>
            <div
              style={{
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between",
                marginBottom: 14,
                flexWrap: "wrap",
                gap: 10,
              }}
            >
              <div style={PANEL_TITLE}>
                🎛 31-BAND GRAPHIC EQUALIZER — PowerSound Pro Style
              </div>
            </div>

            {/* Presets */}
            <div
              style={{
                display: "flex",
                gap: 8,
                marginBottom: 20,
                flexWrap: "wrap",
              }}
            >
              {Object.keys(EQ31_PRESETS)
                .filter((n) => n !== "Flat")
                .map((name) => (
                  <button
                    type="button"
                    key={name}
                    data-ocid="eq31.secondary_button"
                    onClick={() => applyEq31Preset(name)}
                    style={BTN_GOLD}
                  >
                    {name}
                  </button>
                ))}
              <button
                type="button"
                data-ocid="eq31.delete_button"
                onClick={() => applyEq31Preset("Flat")}
                style={BTN_MUTED}
              >
                FLAT RESET
              </button>
            </div>

            {/* DJ Mixer Info */}
            <div
              style={{
                background: "#06090f",
                border: "1px solid #1e2e4a",
                borderRadius: 6,
                padding: "8px 14px",
                marginBottom: 16,
                display: "flex",
                gap: 12,
                flexWrap: "wrap",
              }}
            >
              {["DJ MIX", "CROSSFADE", "BEAT SYNC", "PITCH"].map((lbl) => (
                <div
                  key={lbl}
                  style={{
                    color: "#f5c542",
                    fontSize: 10,
                    fontWeight: 700,
                    letterSpacing: 1,
                  }}
                >
                  ● {lbl}
                </div>
              ))}
            </div>

            {/* 31 Sliders — horizontally scrollable */}
            <div style={{ overflowX: "auto", paddingBottom: 8 }}>
              <div
                style={{
                  display: "flex",
                  gap: 4,
                  alignItems: "flex-start",
                  minWidth: "max-content",
                }}
              >
                {EQ31_FREQS.map((_, idx) => {
                  // Color zones: bass=blue, mid=gold, high=orange
                  const sliderCls =
                    idx < 10
                      ? "eq-slider eq-slider-blue"
                      : idx < 21
                        ? "eq-slider"
                        : "eq-slider eq-slider-orange";
                  return (
                    <div
                      key={EQ31_FREQS[idx]}
                      style={{
                        display: "flex",
                        flexDirection: "column",
                        alignItems: "center",
                        width: 28,
                      }}
                    >
                      {/* Value */}
                      <div
                        style={{
                          fontSize: 9,
                          fontWeight: 700,
                          height: 14,
                          color:
                            eq31[idx] > 0
                              ? "#00ff88"
                              : eq31[idx] < 0
                                ? "#ff6644"
                                : "#1e2e4a",
                          marginBottom: 2,
                          textAlign: "center",
                        }}
                      >
                        {Math.abs(eq31[idx]) >= 1
                          ? (eq31[idx] > 0 ? "+" : "") + eq31[idx].toFixed(0)
                          : ""}
                      </div>
                      {/* Slider — rotate(-90deg) method */}
                      <VerticalSlider
                        value={eq31[idx]}
                        min={-12}
                        max={12}
                        step={0.5}
                        onChange={(v) => updateEq31(idx, v)}
                        sliderClass={sliderCls}
                        height={100}
                        width={24}
                      />
                      {/* Freq label — rotated for space */}
                      <div
                        style={{
                          fontSize: 8,
                          color: "#4a6080",
                          marginTop: 6,
                          transform: "rotate(-55deg)",
                          transformOrigin: "top center",
                          whiteSpace: "nowrap",
                          height: 22,
                        }}
                      >
                        {EQ31_LABELS[idx]}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </section>

        {/* ── Loud Booster + 1700 Volume (side-by-side) ── */}
        <section style={{ marginBottom: 20 }}>
          <div
            style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}
          >
            {/* Loud Booster */}
            <div style={PANEL}>
              <div style={PANEL_TITLE}>⚡ LOUD BOOSTER — CHAIN BLOCK</div>
              <div
                style={{
                  display: "flex",
                  flexDirection: "column",
                  alignItems: "center",
                  gap: 10,
                }}
              >
                <div
                  style={{ color: "#f5c542", fontSize: 24, fontWeight: 900 }}
                >
                  {loudBooster}
                </div>
                <VerticalSlider
                  value={loudBooster}
                  min={0}
                  max={1700}
                  step={1}
                  onChange={updateLoudBooster}
                  sliderClass="eq-slider"
                  height={160}
                  width={40}
                />
                <div
                  style={{ color: "#4a6080", fontSize: 10, letterSpacing: 1 }}
                >
                  0 ─────────── 1700
                </div>
              </div>
            </div>

            {/* 1700 Volume */}
            <div style={PANEL}>
              <div style={PANEL_TITLE}>🔊 VOLUME CONTROL — 1700</div>
              <div
                style={{
                  display: "flex",
                  flexDirection: "column",
                  alignItems: "center",
                  gap: 10,
                }}
              >
                <div
                  style={{ color: "#00ff88", fontSize: 24, fontWeight: 900 }}
                >
                  {masterVolume}
                </div>
                <VerticalSlider
                  value={masterVolume}
                  min={0}
                  max={1700}
                  step={1}
                  onChange={updateMasterVolume}
                  sliderClass="eq-slider eq-slider-green"
                  height={160}
                  width={40}
                />
                <div
                  style={{ color: "#4a6080", fontSize: 10, letterSpacing: 1 }}
                >
                  0 ─────────── 1700
                </div>
              </div>
            </div>
          </div>
        </section>

        {/* ── Stabilizer + Auto Freq Gen ── */}
        <section style={{ marginBottom: 20 }}>
          <div
            style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}
          >
            {/* Stabilizer */}
            <div
              style={{
                ...PANEL,
                border: `1px solid ${commanderOn ? "#00ff88" : "#1e2e4a"}`,
              }}
            >
              <div style={PANEL_TITLE}>
                ⚖ STABILIZER — 1,600,000,000 TITANIUM
              </div>
              <div
                style={{ display: "flex", flexDirection: "column", gap: 12 }}
              >
                {["STAGE 1 — 800M GENTLE", "STAGE 2 — 800M TITANIUM"].map(
                  (stage) => (
                    <div
                      key={stage}
                      style={{ display: "flex", alignItems: "center", gap: 10 }}
                    >
                      <div
                        style={{
                          width: 10,
                          height: 10,
                          borderRadius: "50%",
                          background: commanderOn ? "#00ff88" : "#2a5040",
                          boxShadow: commanderOn ? "0 0 8px #00ff88" : "none",
                        }}
                      />
                      <div
                        style={{
                          color: "#8aa0c0",
                          fontSize: 11,
                          letterSpacing: 1,
                        }}
                      >
                        {stage}
                      </div>
                      <div
                        style={{
                          color: greenText(commanderOn),
                          fontSize: 11,
                          fontWeight: 700,
                          letterSpacing: 1,
                        }}
                      >
                        {commanderOn ? "ONLINE" : "STANDBY"}
                      </div>
                    </div>
                  ),
                )}
                <div style={{ marginTop: 4 }}>
                  {[
                    "NO CLIPPING",
                    "NO LIMITING",
                    "FULL POWER",
                    "SMART CHIP",
                  ].map((lbl) => (
                    <div
                      key={lbl}
                      style={{
                        display: "flex",
                        alignItems: "center",
                        gap: 6,
                        marginBottom: 4,
                      }}
                    >
                      <div
                        style={{
                          width: 6,
                          height: 6,
                          borderRadius: "50%",
                          background: green(commanderOn),
                        }}
                      />
                      <div
                        style={{
                          color: "#4a6080",
                          fontSize: 10,
                          letterSpacing: 1,
                        }}
                      >
                        {lbl}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {/* Auto Freq Generator */}
            <div style={PANEL}>
              <div
                style={{
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "space-between",
                  marginBottom: 14,
                }}
              >
                <div style={PANEL_TITLE}>🎵 AUTO FREQ GENERATOR</div>
                <button
                  type="button"
                  data-ocid="autogen.toggle"
                  onClick={() => setAutoGenOn((v) => !v)}
                  style={autoGenOn ? BTN_GREEN : BTN_MUTED}
                >
                  {autoGenOn ? "ON" : "OFF"}
                </button>
              </div>
              {/* Frequency bars */}
              <div
                style={{
                  display: "flex",
                  gap: 3,
                  alignItems: "flex-end",
                  height: 64,
                  marginBottom: 10,
                }}
              >
                {FREQ_BAR_KEYS.map((fbKey, i) => (
                  <motion.div
                    key={fbKey}
                    animate={{
                      height: `${Math.max(4, (freqBars[i] ?? 0) * 100)}%`,
                    }}
                    transition={{ duration: 0.08 }}
                    style={{
                      flex: 1,
                      background: `hsl(${180 + i * 9}, 80%, 55%)`,
                      borderRadius: 2,
                      minHeight: 4,
                    }}
                  />
                ))}
              </div>
              <div style={{ color: "#4a6080", fontSize: 10, letterSpacing: 1 }}>
                Analyzes song every 500ms • Auto-adjusts EQ bands in real time
              </div>
            </div>
          </div>
        </section>

        {/* ── Footer ── */}
        <footer
          style={{
            textAlign: "center",
            paddingTop: 28,
            borderTop: "1px solid #1e2e4a",
            color: "#4a6080",
            fontSize: 12,
          }}
        >
          © {new Date().getFullYear()}. Built with ❤ using{" "}
          <a
            href={`https://caffeine.ai?utm_source=caffeine-footer&utm_medium=referral&utm_content=${encodeURIComponent(window.location.hostname)}`}
            target="_blank"
            rel="noreferrer"
            style={{ color: "#f5c542", textDecoration: "none" }}
          >
            caffeine.ai
          </a>
        </footer>
      </div>
    </div>
  );
}
